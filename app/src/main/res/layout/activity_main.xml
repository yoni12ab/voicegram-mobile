<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#f5f5f5"
    android:gravity="center">

    <!-- Header -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginBottom="32dp"
        android:text="VoiceGram"
        android:textColor="#2196F3"
        android:textSize="28sp"
        android:textStyle="bold" />

    <!-- Bot List Button -->
    <Button
        android:id="@+id/botListButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:backgroundTint="#4CAF50"
        android:padding="16dp"
        android:text="My Bots"
        android:textColor="#ffffff"
        android:textSize="16sp"
        android:textStyle="bold"
        android:visibility="gone" />

    <!-- Authentication Button -->
    <Button
        android:id="@+id/authButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:backgroundTint="#2196F3"
        android:padding="16dp"
        android:text="Authenticate with Telegram"
        android:textColor="#ffffff"
        android:textSize="16sp"
        android:textStyle="bold" />

    <!-- Info Text -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginTop="32dp"
        android:text="VoiceGram allows you to make voice calls to Telegram bots\nwith speech-to-text and text-to-speech conversion"
        android:textAlignment="center"
        android:textColor="#666666"
        android:textSize="14sp" />

    <!-- Authentication Status -->
    <TextView
        android:id="@+id/authStatusText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginTop="16dp"
        android:text="Not authenticated with Telegram"
        android:textAlignment="center"
        android:textColor="#F44336"
        android:textSize="14sp"
        android:textStyle="bold" />

    <!-- Version Info -->
    <TextView
        android:id="@+id/versionText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginTop="16dp"
        android:text="Version 1.0.26"
        android:textColor="#999999"
        android:textSize="12sp" />

    <!-- Debug Logs Button -->
    <Button
        android:id="@+id/debugLogsButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginTop="16dp"
        android:backgroundTint="#FF9800"
        android:padding="12dp"
        android:text="Export Debug Logs"
        android:textColor="#ffffff"
        android:textSize="12sp" />

</LinearLayout>